# Deya v3.0 — Environment Variables

# ============================================
# AI MODELS
# ============================================

# OpenAI (GPT-4, DALL-E)
OPENAI_API_KEY=sk-your-openai-key

# Anthropic (Claude)
ANTHROPIC_API_KEY=sk-ant-your-anthropic-key

# Google (Gemini)
GOOGLE_API_KEY=your-google-key

# Moonshot (Kimi)
MOONSHOT_API_KEY=your-moonshot-key

# Local AI (Ollama, LocalAI)
OLLAMA_BASE_URL=http://localhost:11434

# ============================================
# VIDEO GENERATION
# ============================================

# KIE.ai (Veo, WAN, Seedance)
KIE_API_KEY=your-kie-key

# Pollinations (Free tier)
POLLINATIONS_API_KEY=optional

# ============================================
# SOCIAL MEDIA
# ============================================

# Telegram Bot
TELEGRAM_BOT_TOKEN=your-telegram-bot-token

# VK
VK_ACCESS_TOKEN=your-vk-token
VK_GROUP_ID=your-group-id

# Instagram
INSTAGRAM_ACCESS_TOKEN=your-instagram-token

# Twitter/X
TWITTER_API_KEY=your-twitter-key
TWITTER_API_SECRET=your-twitter-secret

# Facebook
FACEBOOK_ACCESS_TOKEN=your-facebook-token

# ============================================
# EMAIL
# ============================================

# SendGrid
SENDGRID_API_KEY=your-sendgrid-key

# UniSender
UNISENDER_API_KEY=your-unisender-key

# ============================================
# ANALYTICS
# ============================================

# Google Analytics 4
GA4_PROPERTY_ID=your-ga4-id
GA4_SERVICE_ACCOUNT_KEY=path/to/service-account.json

# Яндекс.Метрика
YANDEX_METRIKA_ID=your-metrika-id
YANDEX_TOKEN=your-yandex-token

# Google Search Console
GSC_SERVICE_ACCOUNT_KEY=path/to/service-account.json

# ============================================
# E-COMMERCE
# ============================================

# WooCommerce
WC_CONSUMER_KEY=your-wc-key
WC_CONSUMER_SECRET=your-wc-secret
WC_STORE_URL=https://your-store.com

# Shopify
SHOPIFY_STORE=your-store.myshopify.com
SHOPIFY_ACCESS_TOKEN=your-shopify-token

# Ozon
OZON_CLIENT_ID=your-ozon-id
OZON_API_KEY=your-ozon-key

# Wildberries
WB_SUPPLIER_ID=your-wb-id
WB_API_KEY=your-wb-key

# ============================================
# CMS / BLOGS
# ============================================

# WordPress
WP_BASE_URL=https://your-blog.com
WP_USERNAME=your-wp-user
WP_APP_PASSWORD=your-wp-app-password

# Medium
MEDIUM_INTEGRATION_TOKEN=your-medium-token

# Ghost
GHOST_ADMIN_API_KEY=your-ghost-key
GHOST_API_URL=https://your-ghost.com

# ============================================
# CRM
# ============================================

# Битрикс24
BITRIX24_WEBHOOK_URL=https://your-bitrix.bitrix24.ru/rest/1/...

# amoCRM
AMOCRM_SUBDOMAIN=your-subdomain
AMOCRM_CLIENT_ID=your-client-id
AMOCRM_CLIENT_SECRET=your-client-secret

# ============================================
# STORAGE
# ============================================

# Google Drive
GOOGLE_DRIVE_SERVICE_ACCOUNT=path/to/service-account.json

# Dropbox
DROPBOX_ACCESS_TOKEN=your-dropbox-token

# ============================================
# NOTION
# ============================================

NOTION_TOKEN=secret_your_notion_token
NOTION_DATABASE_ID=your-database-id

# ============================================
# SECURITY
# ============================================

# Encryption
ENCRYPTION_KEY=your-32-char-encryption-key

# IP Whitelist (comma separated)
IP_WHITELIST=127.0.0.1,::1

# ============================================
# OPENCLAW
# ============================================

OPENCLAW_GATEWAY_URL=https://your-gateway.openclaw.ai
OPENCLAW_API_KEY=your-openclaw-key

# ============================================
# SYSTEM
# ============================================

NODE_ENV=production
LOG_LEVEL=info
PORT=3000

# Timezone
TZ=Europe/Berlin
